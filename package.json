{
  "name": "gbfeeds-rebuild",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/verify-env.ts && tsx scripts/validate-harvests.ts && tsx scripts/validate-products.ts && tsx scripts/validate-images.ts && tsx scripts/validate-client-data-boundary.ts && next build",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "start": "serve -s out -p 4173",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "lhci autorun --config=./lighthouserc.json"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "clsx": "2.1.1",
    "framer-motion": "11.18.2",
    "gsap": "3.15.0",
    "lenis": "1.3.23",
    "lucide-react": "0.469.0",
    "next": "15.5.15",
    "next-mdx-remote": "6.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "2.6.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260506.1",
    "@next/bundle-analyzer": "15.5.15",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@typescript-eslint/eslint-plugin": "8.21.0",
    "@typescript-eslint/parser": "8.21.0",
    "autoprefixer": "10.4.20",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-boundaries": "5.4.0",
    "mapshaper": "0.7.9",
    "postcss": "8.5.1",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.6.10",
    "serve": "14.2.6",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "@lhci/cli": "0.14.0",
    "@lhci/utils": "0.14.0",
    "@playwright/test": "1.51.1",
    "wait-on": "8.0.3",
    "wrangler": "4.88.0"
  }
}
