# ─────────────────────────────────────────────────────────────────────────────
# GB Feeds — .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env.local` for local dev. Never commit `.env.local`.
#
# This file holds ONLY public, build-time vars (`NEXT_PUBLIC_*`).
# Worker secrets (RESEND_API_KEY, TURNSTILE_SECRET_KEY) are managed
# separately via `wrangler secret put` against the cloudflare-worker/
# project — they NEVER live in the Next.js build environment.
#
# Production source of truth: Cloudflare Pages dashboard env vars.
# Local dev source of truth: this file (`.env.local`).
# ─────────────────────────────────────────────────────────────────────────────

# Canonical site URL — used for sitemap, canonicals, OG image absolutes.
# Local: http://localhost:3000  •  Preview: https://<branch>.gbfeeds-rebuild.pages.dev
# Production: https://gbfeeds.com
NEXT_PUBLIC_SITE_URL=https://gbfeeds.com

# Google Analytics 4 measurement ID (recon-confirmed continuity).
NEXT_PUBLIC_GA_ID=G-BF2FDR6KMM

# Google Tag Manager container — leave empty unless GTM is adopted.
NEXT_PUBLIC_GTM_ID=

# Cloudflare Turnstile site key (public by design).
# Generate at: https://dash.cloudflare.com → Turnstile → Add site.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_REPLACE_WITH_REAL_SITE_KEY

# Cloudflare Worker forms endpoint. Includes the path (/contact).
# Default Workers URL until custom domain (forms.gbfeeds.com) is bound.
NEXT_PUBLIC_FORM_ENDPOINT=https://gbfeeds-forms.<account>.workers.dev/contact

# TrustedSite / McAfee Secure customer ID. Empty = badge component no-ops.
NEXT_PUBLIC_TRUSTEDSITE_ID=

# Reamaze chat brand UUID. Empty = chat dropped, mailto fallback rendered.
NEXT_PUBLIC_REAMAZE_BRAND_UUID=

# Field Club feature flag. `false` = waitlist-only. `true` after the
# subscription Stripe Payment Link is created in Phase 8.
NEXT_PUBLIC_FEATURE_FIELD_CLUB=false
